{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "singleQuote": true,
  "ignorePatterns": [
    "dist/**",
    "site/**",
    "assets/**",
    "node_modules/**",
    "package-lock.json",
    "docs/node_modules/**",
    "docs/.astro/**",
    "docs/package-lock.json",
    "docs/**/*.mdx",
    "docs/**/*.md",
    "coverage/**"
  ]
}
