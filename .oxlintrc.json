{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "builtin": true,
    "browser": true
  },
  "ignorePatterns": ["dist/**", "site/**", "node_modules/**"],
  "rules": {
    "eslint/no-underscore-dangle": ["warn", { "allow": ["__u"] }]
  }
}
