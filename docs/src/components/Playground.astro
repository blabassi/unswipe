---
import { Code } from '@astrojs/starlight/components';

interface Props {
  id: string;
  slides?: string[];
  label?: string;
  align?: 'start' | 'center' | 'end';
  axis?: 'x' | 'y';
  plugins?: string;
  slideSelector?: string;
  /** CSS value for `--unswipe-slide-min-width` (controls how many slides fit). */
  slideMinWidth?: string;
  /** JS option — how many slides fit in view. */
  slidesPerView?: number;
  slidesToScroll?: number;
  status?: boolean;
  code?: string;
  title?: string;
  lang?: string;
}
const {
  id,
  slides = ['Slide 1', 'Slide 2', 'Slide 3'],
  label = 'Carousel',
  align = 'start',
  axis = 'x',
  plugins = '',
  slideSelector,
  slideMinWidth,
  slidesPerView,
  slidesToScroll,
  status = true,
  code,
  title = 'example.js',
  lang = 'js',
} = Astro.props;
---

<div class="playground not-content" data-pagefind-ignore>
  <div class="playground__preview">
    <div
      id={id}
      class:list={['carousel', axis === 'y' && 'carousel--y']}
      data-unswipe
      data-label={label}
      data-align={align}
      data-axis={axis}
      data-plugins={plugins}
      data-slide={slideSelector}
      data-slides-to-scroll={slidesToScroll}
      data-slides-per-view={slidesPerView}
      data-fixed-slide-width={slideMinWidth || slidesPerView ? '' : undefined}
      style={slideMinWidth
        ? `--unswipe-slide-min-width: ${slideMinWidth}`
        : undefined}
    >
      {
        slides.map((text) =>
          slideSelector ? (
            <article class="slide item">{text}</article>
          ) : (
            <div class="slide">{text}</div>
          ),
        )
      }
    </div>
    {
      status && (
        <p class="playground__status" data-unswipe-status={id}>
          Active slide: 1
        </p>
      )
    }
    <slot name="controls" />
  </div>
  <div class="playground__code">
    {code ? <Code code={code} lang={lang} title={title} /> : <slot />}
  </div>
</div>
