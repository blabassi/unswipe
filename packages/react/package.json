{
  "name": "@unswipe/react",
  "version": "1.0.0",
  "description": "React bindings for Unswipe",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:react --external:unswipe && esbuild src/index.ts --bundle --format=cjs --outfile=dist/index.cjs --external:react --external:unswipe && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^6.0.3",
    "unswipe": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "unswipe": ">=1.0.0"
  }
}
