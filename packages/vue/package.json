{
  "name": "@unswipe/vue",
  "version": "1.0.0",
  "description": "Vue bindings for Unswipe",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:vue --external:unswipe && esbuild src/index.ts --bundle --format=cjs --outfile=dist/index.cjs --external:vue --external:unswipe && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "unswipe": "workspace:*",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "unswipe": ">=1.0.0",
    "vue": ">=3"
  }
}
